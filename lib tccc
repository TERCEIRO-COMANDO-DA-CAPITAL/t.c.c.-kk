-- FluentMobileLib: High-Performance Luau UI
local FluentLib = {
    Themes = {
        Main = Color3.fromRGB(20, 20, 20),
        Accent = Color3.fromRGB(0, 120, 215),
        Text = Color3.fromRGB(255, 255, 255),
        Transparency = 0.3
    }
}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

function FluentLib:CreateWindow(Config)
    local Window = {
        Tabs = {},
        ActiveTab = nil,
        Minimized = false
    }

    -- Root ScreenGui
    local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    ScreenGui.Name = "FluentMobileUI"
    ScreenGui.ResetOnSpawn = false

    -- Main Container (Semi-Transparent Acrylic)
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.new(0, 450, 0, 300)
    MainFrame.Position = UDim2.new(0.5, -225, 0.5, -150)
    MainFrame.BackgroundColor3 = self.Themes.Main
    MainFrame.BackgroundTransparency = self.Themes.Transparency
    MainFrame.ClipsDescendants = true
    
    local Corner = Instance.new("UICorner", MainFrame)
    Corner.CornerRadius = UDim.new(0, 12)

    local Stroke = Instance.new("UIStroke", MainFrame)
    Stroke.Thickness = 1.5
    Stroke.Color = Color3.fromRGB(60, 60, 60)
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Bubble Minimize Button
    local Bubble = Instance.new("TextButton", ScreenGui)
    Bubble.Size = UDim2.new(0, 50, 0, 50)
    Bubble.Position = UDim2.new(0.05, 0, 0.1, 0)
    Bubble.Visible = false
    Bubble.Text = "F"
    Bubble.BackgroundColor3 = self.Themes.Accent
    Instance.new("UICorner", Bubble).CornerRadius = UDim.new(1, 0)

    -- Toggle Logic
    local function ToggleUI()
        Window.Minimized = not Window.Minimized
        MainFrame.Visible = not Window.Minimized
        Bubble.Visible = Window.Minimized
    end
    Bubble.MouseButton1Click:Connect(ToggleUI)

    -- Tab System Navigation
    local Nav = Instance.new("Frame", MainFrame)
    Nav.Size = UDim2.new(0, 130, 1, 0)
    Nav.BackgroundTransparency = 1
    
    local TabContainer = Instance.new("ScrollingFrame", MainFrame)
    TabContainer.Position = UDim2.new(0, 140, 0, 10)
    TabContainer.Size = UDim2.new(1, -150, 1, -20)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 2

    local TabList = Instance.new("UIListLayout", TabContainer)
    TabList.Padding = UDim.new(0, 5)

    -- Element Factory (The "Make/Refresh/Change" engine)
    function Window:AddTab(Name, Icon)
        local Tab = { Elements = {} }
        local TabBtn = Instance.new("TextButton", Nav)
        -- ... Tab logic ...

        function Tab:AddToggle(ID, Text, Default, Callback)
            local Toggle = { Value = Default }
            local Frame = Instance.new("Frame", TabContainer)
            Frame.Size = UDim2.new(1, 0, 0, 35)
            Frame.BackgroundTransparency = 0.8
            Frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            
            local Label = Instance.new("TextLabel", Frame)
            Label.Text = "  " .. Text
            Label.Size = UDim2.new(1, 0, 1, 0)
            Label.TextColor3 = FluentLib.Themes.Text
            Label.BackgroundTransparency = 1
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local Status = Instance.new("Frame", Frame)
            Status.Size = UDim2.new(0, 40, 0, 20)
            Status.Position = UDim2.new(1, -45, 0.5, -10)
            Status.BackgroundColor3 = Default and FluentLib.Themes.Accent or Color3.fromRGB(100,100,100)
            Instance.new("UICorner", Status).CornerRadius = UDim.new(1,0)

            -- Force Update / Refresh Method
            function Toggle:Set(NewValue)
                Toggle.Value = NewValue
                TweenService:Create(Status, TweenInfo.new(0.2), {
                    BackgroundColor3 = NewValue and FluentLib.Themes.Accent or Color3.fromRGB(100,100,100)
                }):Play()
                Callback(NewValue)
            end

            Frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Toggle:Set(not Toggle.Value)
                end
            end)

            return Toggle
        end

        function Tab:AddSlider(ID, Text, Min, Max, Default, Callback)
            local Slider = { Value = Default }
            local Frame = Instance.new("Frame", TabContainer)
            Frame.Size = UDim2.new(1, 0, 0, 45)
            Frame.BackgroundTransparency = 0.9
            
            local Label = Instance.new("TextLabel", Frame)
            Label.Text = "  " .. Text .. ": " .. Default
            Label.Size = UDim2.new(1, 0, 0, 20)
            Label.BackgroundTransparency = 1
            Label.TextColor3 = Color3.fromRGB(200, 200, 200)

            local Bar = Instance.new("Frame", Frame)
            Bar.Size = UDim2.new(0.9, 0, 0, 4)
            Bar.Position = UDim2.new(0.05, 0, 0.7, 0)
            Bar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

            local Fill = Instance.new("Frame", Bar)
            Fill.Size = UDim2.new((Default - Min)/(Max - Min), 0, 1, 0)
            Fill.BackgroundColor3 = FluentLib.Themes.Accent

            function Slider:Set(NewVal)
                NewVal = math.clamp(NewVal, Min, Max)
                Slider.Value = NewVal
                Label.Text = "  " .. Text .. ": " .. NewVal
                Fill.Size = UDim2.new((NewVal - Min)/(Max - Min), 0, 1, 0)
                Callback(NewVal)
            end

            -- Touch/Mouse Input logic here
            return Slider
        end

        function Tab:AddDiscordEmbed(InviteCode)
            local Embed = Instance.new("Frame", TabContainer)
            Embed.Size = UDim2.new(1, -10, 0, 80)
            Embed.BackgroundColor3 = Color3.fromRGB(88, 101, 242) -- Discord Blurple
            local Corner = Instance.new("UICorner", Embed)
            
            local Title = Instance.new("TextLabel", Embed)
            Title.Text = "Join our Discord"
            Title.Position = UDim2.new(0, 10, 0, 10)
            Title.TextColor3 = Color3.new(1, 1, 1)
            
            local Join = Instance.new("TextButton", Embed)
            Join.Size = UDim2.new(0, 80, 0, 30)
            Join.Position = UDim2.new(1, -90, 0.5, -15)
            Join.Text = "Copy Link"
            Join.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Join.TextColor3 = Color3.new(0,0,0)
            
            Join.MouseButton1Click:Connect(function()
                setclipboard("https://discord.gg/" .. InviteCode)
            end)
        end

        return Tab
    end

    -- Draggable (Mobile & PC Support)
    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return Window
end

return FluentLib
